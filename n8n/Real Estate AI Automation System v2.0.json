    {
      "parameters": {
        "jsCode": "const lead = $('Supabase: Fetch Lead').first().json[0] || $('Supabase: Create New Lead').first().json[0];\nconst history = $('Supabase: Fetch Last 10 Messages').all().map(item => item.json);\nconst inboundMessage = $('Webhook: Meta DM/Comment').first().json.body.entry[0].messaging[0].message.text;\n\nreturn [{\n  json: {\n    message: inboundMessage,\n    history: history.reverse().map(h => ({ sender: h.sender, message: h.message })),\n    lead_data: {\n      budget: lead.budget || null,\n      location: lead.location || null,\n      property_type: lead.property_type || null,\n      timeline: lead.timeline || null,\n      status: lead.status || 'QUALIFYING'\n    },\n    lead_id: lead.id,\n    instagram_id: lead.instagram_id\n  }\n}];"
      },
      "id": "951e6318-1fef-497d-8e33-c8d514c9bf5d",
