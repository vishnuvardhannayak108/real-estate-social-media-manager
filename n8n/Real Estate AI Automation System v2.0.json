    {
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.OPENAI_API_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "model",
              "value": "gpt-4o"
            },
            {
              "name": "messages",
              "value": "=[{\"role\":\"system\",\"content\":\"You are a real estate sales assistant qualifying leads via Instagram DMs.\\n\\nYour job:\\n- Detect buyer intent, budget, location, property type, timeline\\n- Identify if the lead is in negotiation mode\\n- Decide if a call should be booked\\n- Always respond in valid JSON only — no prose, no markdown\\n\\nRULES:\\n1. If lead shows negotiation signals → set status NEGOTIATION\\n2. If lead is qualified and interested → set trigger_booking true\\n3. Never make up property data\\n4. Keep chat_response conversational, under 100 words\\n5. Always populate all fields — use null if unknown\\n\\nOUTPUT SCHEMA (strict JSON only):\\n{\\n  \\\"chat_response\\\": string (max 100 words),\\n  \\\"status\\\": \\\"QUALIFYING\\\" | \\\"QUALIFIED\\\" | \\\"NEGOTIATION\\\" | \\\"CALL_BOOKED\\\" | \\\"NURTURE\\\" | \\\"CLOSED\\\",\\n  \\\"trigger_booking\\\": boolean,\\n  \\\"lead_data\\\": {\\n    \\\"budget\\\": string | null,\\n    \\\"location\\\": string | null,\\n    \\\"property_type\\\": string | null,\\n    \\\"timeline\\\": string | null\\n  }\\n}\"},{\"role\":\"user\",\"content\":\"={{ JSON.stringify($json) }}\"}]"
            },
            {
              "name": "temperature",
              "value": "=0.3"
            },
            {
              "name": "max_tokens",
              "value": "=500"
            }
          ]
        },
        "options": {}
      },
      "id": "51e0ab47-6325-4d55-b6d1-51fe1f2ae9a8",
      "name": "HTTP: Call OpenAI API",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        1648,
        448
      ]
    },
    {
      "parameters": {
        "jsCode": "const rawContent = $input.first().json.choices[0].message.content;\nlet parsed;\ntry {\n  const cleaned = rawContent.replace(/```json|```/g, '').trim();\n  parsed = JSON.parse(cleaned);\n} catch(e) {\n  parsed = {\n    chat_response: \"Thanks for reaching out! Let me connect you with our team shortly.\",\n    status: \"QUALIFYING\",\n    trigger_booking: false,\n    lead_data: { budget: null, location: null, property_type: null, timeline: null }\n  };\n}\n\nconst validStatuses = ['QUALIFYING','QUALIFIED','NEGOTIATION','CALL_BOOKED','NURTURE','CLOSED'];\nif (!validStatuses.includes(parsed.status)) parsed.status = 'QUALIFYING';\nif (typeof parsed.trigger_booking !== 'boolean') parsed.trigger_booking = false;\nif (!parsed.chat_response || parsed.chat_response.trim() === '') {\n  parsed.chat_response = \"Thanks for reaching out! Let me connect you with our team shortly.\";\n}\n\nconst leadId = $('Code: Build AI Input Payload').first().json.lead_id;\nconst instagramId = $('Code: Build AI Input Payload').first().json.instagram_id;\nconst inboundMessage = $('Code: Build AI Input Payload').first().json.message;\n\nreturn [{ json: { ...parsed, lead_id: leadId, instagram_id: instagramId, inbound_message: inboundMessage } }];"
      },
      "id": "c4834860-09de-4e5a-9045-507e7c709bd2",
      "name": "Code: Validate & Parse AI Output",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
