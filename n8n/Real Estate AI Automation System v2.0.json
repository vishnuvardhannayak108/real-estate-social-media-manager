      "id": "b035ce22-57af-45b1-bacd-5f9989b17b5d",
      "name": "Supabase: Fetch Leads for Follow-up",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2,
      "position": [
        -352,
        1616
      ]
    },
    {
      "parameters": {
        "jsCode": "const leads = $input.all().map(item => item.json);\nconst now = Date.now();\nconst results = [];\n\nfor (const lead of leads) {\n  const lastChat = new Date(lead.last_message_at || lead.created_at).getTime();\n  const hoursSinceContact = (now - lastChat) / (1000 * 60 * 60);\n  let followUpType = null;\n\n  if (hoursSinceContact >= 72 && lead.status === 'CALL_BOOKED') {\n    followUpType = 'PAYMENT_NUDGE';\n  } else if (hoursSinceContact >= 48 && lead.status === 'QUALIFIED') {\n    followUpType = 'BOOKING_NUDGE';\n  } else if (hoursSinceContact >= 24 && lead.status === 'QUALIFYING') {\n    followUpType = 'REMINDER';\n  }\n\n  if (followUpType) {\n    results.push({ json: { ...lead, followUpType } });\n  }\n}\n\nreturn results;"
      },
